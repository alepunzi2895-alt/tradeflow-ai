# --- TradeFlow AI Configuration ---
# Rename this file to .env and fill in the values

PORT=3000

# Anthropic (Claude) API
ANTHROPIC_API_KEY=your_anthropic_key_here

# Turso Database
TURSO_DB_URL=libsql://your-db-name-user.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token

# User Authentication
JWT_SECRET=your_random_jwt_secret_here

# GitHub Integration (Knowledge Base & COT)
GITHUB_TOKEN=your_github_classic_token_with_repo_scope
GITHUB_OWNER=alepunzi2895-alt
GITHUB_REPO=tradeflow-ai

# MT5 Bot Configuration
MT5_LOGIN=your_mt5_account_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server_name
SYMBOL=GOLD

# Production Vercel URL (for Hybrid approach)
VERCEL_URL=https://tradeflow-ai-delta.vercel.app
MT5_BOT_SECRET=tradeflow-mt5-secret
