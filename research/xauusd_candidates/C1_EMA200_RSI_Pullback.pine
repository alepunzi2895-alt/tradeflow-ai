//@version=6
strategy("C1_EMA200_RSI_Pullback", overlay=true, initial_capital=10000,
     default_qty_type=strategy.fixed, default_qty_value=1,
     currency=currency.USD, pyramiding=0,
     commission_type=strategy.commission.cash_per_contract, commission_value=0,
     slippage=0, calc_on_every_tick=false)

// ── C1: EMA200 trend filter + RSI(14) pullback cross 40/60 ──────────────────
// SCARTATA presto: PF full-period 1.004 (sostanziale breakeven), non testato IS/OOS
ema200 = ta.ema(close, 200)
rsi = ta.rsi(close, 14)
atr = ta.atr(14)

bullTrend = close > ema200
bearTrend = close < ema200

buyTrigger  = ta.crossover(rsi, 40) and bullTrend
sellTrigger = ta.crossunder(rsi, 60) and bearTrend

barOk = bar_index >= 210

var float entryAtr = na
if buyTrigger and barOk and strategy.position_size == 0
    entryAtr := atr
    strategy.entry("Long", strategy.long)
if sellTrigger and barOk and strategy.position_size == 0
    entryAtr := atr
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("XL", "Long", limit=strategy.position_avg_price + entryAtr*2.5, stop=strategy.position_avg_price - entryAtr*1.2)
if strategy.position_size < 0
    strategy.exit("XS", "Short", limit=strategy.position_avg_price - entryAtr*2.5, stop=strategy.position_avg_price + entryAtr*1.2)

plot(ema200, color=color.yellow)
