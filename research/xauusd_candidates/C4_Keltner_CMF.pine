//@version=6
strategy("C4_Keltner_CMF", overlay=true, initial_capital=10000,
     default_qty_type=strategy.fixed, default_qty_value=1,
     currency=currency.USD, pyramiding=0,
     commission_type=strategy.commission.cash_per_contract, commission_value=0,
     slippage=0, calc_on_every_tick=false)

// ── C4: Keltner Channel(20,2xATR10) breakout + Chaikin Money Flow(20) confirm ──
kMid = ta.ema(close, 20)
kAtr = ta.atr(10)
kUp = kMid + 2.0*kAtr
kDn = kMid - 2.0*kAtr

mfm = (high == low) ? 0.0 : ((close-low)-(high-close))/(high-low)
mfv = mfm * volume
cmf = ta.sma(mfv,20) / ta.sma(volume,20)

atr = ta.atr(14)

buyTrigger  = ta.crossover(close, kUp) and cmf > 0
sellTrigger = ta.crossunder(close, kDn) and cmf < 0

barOk = bar_index >= 30

var float entryAtr = na
if buyTrigger and barOk and strategy.position_size == 0
    entryAtr := atr
    strategy.entry("Long", strategy.long)
if sellTrigger and barOk and strategy.position_size == 0
    entryAtr := atr
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("XL", "Long", limit=strategy.position_avg_price + entryAtr*2.5, stop=strategy.position_avg_price - entryAtr*1.2)
if strategy.position_size < 0
    strategy.exit("XS", "Short", limit=strategy.position_avg_price - entryAtr*2.5, stop=strategy.position_avg_price + entryAtr*1.2)

plot(kUp, color=color.blue)
plot(kDn, color=color.blue)
